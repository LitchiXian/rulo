[server]
ipaddr = "0.0.0.0"
port = 13000
# 全局 HTTP 请求体上限（字节），防恶意大包 DoS，应 ≥ storage.max_file_size
body_limit = 20971520  # 20 MB

[jwt]
secret = "rulo_jwt_secret_key_change_me_in_production"
expire_hours = 24

[database]
url = "postgres://rulo:123456@127.0.0.1:5432/rulo"
max_connections = 5
acquire_timeout_secs = 3

[redis]
url = "redis://127.0.0.1:6379/0"

[ai]
api_key = "demokey"
base_url = "https://open.bigmodel.cn/api/paas/v4/chat/completions"
model = "demo_mod"

[storage]
endpoint = "http://127.0.0.1:9000"
bucket = "rulo"
access_key = "rustfsadmin"
secret_key = "rustfsadmin"
region = "us-east-1"
# 单文件业务上限（字节），上传 handler 中超过返回业务错误
max_file_size = 10485760  # 10 MB
allowed_types = ["image/jpeg", "image/png", "image/gif", "image/webp", "image/svg+xml"]
# 对外公网 URL 前缀，生产环境通过环境变量 RULO__STORAGE__PUB_URL 设置
# 例：RULO__STORAGE__PUB_URL=https://sosdan.cn/storage
# pub_url = ""  # 本地开发留空，不替换

[rate_limit]
# 登录/注册：每 IP 每分钟最大请求数
login_per_minute = 10
# AI 聊天：每用户每分钟最大请求数
ai_per_minute = 20
# 全局：每 IP 每分钟最大请求数
global_per_minute = 200
